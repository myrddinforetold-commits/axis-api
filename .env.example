# Axis Moltbot API Configuration

# Server
PORT=3100
HOST=0.0.0.0

# API Authentication
API_KEY=your-secret-api-key

# OpenClaw Gateway Connection
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=your-gateway-token
OPENCLAW_HOME=/root/.openclaw
BRAVE_API_KEY=your-brave-search-api-key

# CAL 9000 (isolated conversational agent)
CAL_ROOT_DIR=./agents/cal9000
CAL_LLM_PROVIDER=openai
CAL_OPENAI_CHAT_MODEL=gpt-5-mini
CAL_OPENAI_API_KEY=your-openai-api-key
CAL_OPENCLAW_MODEL=openclaw/cal9000
CAL_OPENCLAW_GATEWAY_URL=http://127.0.0.1:18791
CAL_OPENCLAW_GATEWAY_TOKEN=your-cal-gateway-token
CAL_MAX_HISTORY_MESSAGES=80
CAL_MAX_HISTORY_CHARS=9000
CAL_MAX_TOKENS=320
CAL_WEB_SEARCH_ENABLED=true
CAL_BRAVE_API_KEY=your-brave-search-api-key
CAL_WEB_TIMEOUT_MS=3500
CAL_WEB_MAX_SNIPPETS=4
CAL_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
CAL_TREASURY_POLL_INTERVAL_MS=30000
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
CAL_ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
CAL_ELEVENLABS_OUTPUT_FORMAT=mp3_22050_32
CAL_ELEVENLABS_STREAMING_LATENCY=4
CAL_TTS_TIMEOUT_MS=7000
CAL_TTS_PROVIDER=auto
CAL_TTS_SPEAK_MAX_CHARS=320
CAL_OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
CAL_OPENAI_REALTIME_VOICE=ash
CAL_OPENAI_REALTIME_TEMPERATURE=0.6
CAL_OPENAI_REALTIME_MAX_OUTPUT_TOKENS=220
CAL_REALTIME_HISTORY_EXCHANGES=6
CAL_REALTIME_HISTORY_MAX_CHARS=3000

# Legacy aliases still supported by code:
# MOLTBOT_GATEWAY_URL=http://127.0.0.1:18789
# MOLTBOT_GATEWAY_TOKEN=your-gateway-token
