{
  "name": "axis-moltbot-api",
  "version": "0.1.0",
  "description": "HTTP API gateway for Axis-Moltbot integration",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker:cal-treasury": "tsx watch src/workers/cal_treasury_watcher.ts",
